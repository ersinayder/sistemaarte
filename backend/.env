# Copie para .env e preencha antes de rodar o servidor
PORT=3001
NODE_ENV=development

# OBRIGATÓRIO — sem isso o servidor NÃO sobe em produção
# Gere um valor forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=segredao

# Origens permitidas no CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
