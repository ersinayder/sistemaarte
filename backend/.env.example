# Copie para .env e preencha

# OBRIGATÓRIO em produção — string aleatória longa
JWT_SECRET=troque-por-uma-string-aleatoria-longa-aqui

# Porta do servidor (padrão 3001)
PORT=3001

# Origens permitidas no CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Ambiente: development | production
NODE_ENV=development

# ── WhatsApp via Meta Cloud API ─────────────────────────────────────────────
# Como obter:
#   1. Acesse https://developers.facebook.com e crie um app (tipo: Business)
#   2. Adicione o produto "WhatsApp" ao app
#   3. WHATSAPP_PHONE_ID: em WhatsApp > Primeiros passos > "De" — copie o Phone Number ID
#   4. WHATSAPP_TOKEN: gere um token de acesso permanente via System User no Business Manager
# Deixe em branco para desabilitar o envio automático
WHATSAPP_PHONE_ID=seu_phone_number_id_aqui
WHATSAPP_TOKEN=seu_token_permanente_aqui
# Para desabilitar sem remover as vars:
WHATSAPP_ENABLED=true

# Templates cadastrados no Meta (devem ser aprovados antes de usar):
#   os_pronta          — disparado automaticamente ao mudar status para "Pronto"
#   confirmacao_pedido — disparado manualmente ao registrar pedido
